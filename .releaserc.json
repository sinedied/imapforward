{
  "branches": ["main"],
  "tagFormat": "${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "just release-prepare ${nextRelease.version}"
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md", "src/main.go"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [
        {"path": "dist/imapforward-linux-amd64", "label": "imapforward-linux-amd64"},
        {"path": "dist/imapforward-linux-arm64", "label": "imapforward-linux-arm64"},
        {"path": "dist/imapforward-darwin-amd64", "label": "imapforward-darwin-amd64"},
        {"path": "dist/imapforward-darwin-arm64", "label": "imapforward-darwin-arm64"},
        {"path": "dist/imapforward-windows-amd64.exe", "label": "imapforward-windows-amd64.exe"}
      ]
    }]
  ]
}
